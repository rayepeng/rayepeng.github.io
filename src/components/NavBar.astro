---
import Logo from '~/components/Logo.vue'
import ToggleTheme from '~/components/ToggleTheme.vue'
import BackToTop from '~/components/BackToTop.vue'

/**
 * NavBar items — set enabled: false to hide any nav item temporarily.
 * Items with `alwaysShow: true` are always visible (not hidden on mobile).
 */
const navItems = [
  { href: '/archive', title: 'Archive', icon: 'i-ri-archive-line', label: 'Archive', enabled: true, alwaysShow: true },
  { href: '/posts', title: 'Blog', icon: 'i-ri-article-line', label: 'Blog', enabled: true, alwaysShow: true },
  { href: '/categories', title: 'Categories', icon: 'i-ri-folder-line', label: 'Categories', enabled: true, alwaysShow: false },
  { href: '/tags', title: 'Tags', icon: 'i-ri-price-tag-3-line', label: 'Tags', enabled: true, alwaysShow: false },
  { href: '/projects', title: 'Projects', icon: 'i-ri-lightbulb-line', label: 'Projects', enabled: true, alwaysShow: true },
  { href: '/about', title: 'About', icon: 'i-ri-user-line', label: 'About', enabled: true, alwaysShow: true },
  { href: '/friends', title: 'Friends', icon: 'i-ri-links-line', label: 'Friends', enabled: true, alwaysShow: false },
  { href: 'https://photo.rayepeng.net/', title: 'Photo', icon: 'i-ri-camera-3-line', label: '', enabled: true, alwaysShow: false, external: true },
  { href: 'https://rayepeng.net/workouts_page/', title: 'Running', icon: 'i-ri-run-line', label: '', enabled: true, alwaysShow: false, external: true },
  { href: 'https://github.com/rayepeng', title: 'GitHub', icon: 'i-uil-github-alt', label: '', enabled: true, alwaysShow: false, external: true },
  { href: '/feed', title: 'RSS', icon: 'i-la-rss-square', label: '', enabled: true, alwaysShow: false, iconStyle: 'font-size:1.25rem; margin: 0 -0.125rem;' },
]

const visibleItems = navItems.filter(i => i.enabled)
---

<header class="header z-40">
  <a
    href="/"
    class="w-12 h-12 absolute xl:fixed m-5 select-none outline-none block"
    aria-label="Home"
  >
    <Logo client:load />
  </a>

  <BackToTop client:idle />

  <nav class="nav">
    <div class="spacer" />
    <div class="right" print:op0>
      {visibleItems.map(item => (
        <a
          href={item.href}
          title={item.title}
          class:list={[!item.alwaysShow && 'lt-md:hidden']}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
        >
          {item.label && <span class="lt-md:hidden">{item.label}</span>}
          {item.icon && <div class:list={[item.icon, item.label ? 'md:hidden' : '']} style={item.iconStyle || ''} />}
        </a>
      ))}
      <ToggleTheme client:load />
    </div>
  </nav>
</header>

<style>
  .header h1 {
    margin-bottom: 0;
  }
  .logo {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
  }
  .nav {
    padding: 2rem;
    width: 100%;
    display: grid;
    grid-template-columns: auto max-content;
    box-sizing: border-box;
  }
  .nav > * {
    margin: auto;
  }
  .nav img {
    margin-bottom: 0;
  }
  .nav a {
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
    opacity: 0.6;
    outline: none;
  }
  .nav a:hover {
    opacity: 1;
    text-decoration-color: inherit;
  }
  .nav .right {
    display: grid;
    grid-gap: 1.2rem;
    grid-auto-flow: column;
  }
  .nav .right > * {
    margin: auto;
  }
</style>