---
import NavBar from '~/components/NavBar.astro'
import Footer from '~/components/Footer.astro'

interface Props {
  title: string
  date: string
  headings?: { depth: number; slug: string; text: string }[]
}

const { title, date } = Astro.props

function formatDate(d: string) {
  const date = new Date(d)
  const now = new Date()
  const opts: Intl.DateTimeFormatOptions = date.getFullYear() === now.getFullYear()
    ? { month: 'short', day: 'numeric' }
    : { month: 'short', day: 'numeric', year: 'numeric' }
  return date.toLocaleDateString('en-US', opts)
}
---

<NavBar />

<article class="prose m-auto mb-8 slide-enter-content">
  <h1>{title}</h1>
  <p class="post-date opacity-50 !-mt-6 mb-8">
    <time datetime={date}>{formatDate(date)}</time>
  </p>
  <slot />
</article>

<div class="prose m-auto mt-8 mb-8 slide-enter animate-delay-500">
  <br>
  <span font-mono op50>&gt; </span>
  <a
    href="/posts"
    class="font-mono no-underline op50 hover:op75"
  >cd ..</a>
</div>

<Footer />

<style>
  .post-date {
    opacity: 0.5;
    margin-top: -1.5rem !important;
    margin-bottom: 2rem;
    font-size: 0.9em;
  }
</style>