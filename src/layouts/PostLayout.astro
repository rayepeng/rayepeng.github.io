---
import { formatDate } from '~/logics'

interface Props {
  title: string
  date: string
  description?: string
  image?: string
  lang?: string
  tags?: string[]
  category?: string
  headings?: { depth: number; slug: string; text: string }[]
}

const {
  title,
  date,
  description = '',
  image = '',
  lang = 'en',
  tags = [],
  category = '',
  headings = [],
} = Astro.props
const siteUrl = Astro.site?.toString() || 'https://rayepeng.github.io/'
const ogImage = image || `${siteUrl}og/${Astro.params.slug}.png`
const canonicalURL = new URL(Astro.url.pathname, siteUrl)

// Only h1 and h2 for outline
const outline = headings.filter(h => h.depth <= 2)
---

<Fragment slot="og">
  <meta property="og:type" content="article" />
  <meta property="article:published_time" content={date} />
  <meta property="article:author" content="Raye" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:image" content={ogImage} />
  {tags.map(tag => <meta property="article:tag" content={tag} />)}
</Fragment>

<article class="prose m-auto mb-8 slide-enter-content">
  <h1>{title}</h1>
  <div class="post-meta">
    <time datetime={date}>{formatDate(date, false)}</time>
    {tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/tags#tag-${encodeURIComponent(tag)}`} class="post-tag">#{tag}</a>
        ))}
      </div>
    )}
  </div>

  {image && (
    <div class="post-cover" id="post-cover">
      <img src={image} alt={title} />
    </div>
  )}

  {!image && (
    <div class="post-cover" id="post-cover" style="display:none"></div>
  )}

  {outline.length > 1 && (
    <nav class="post-outline" id="post-outline">
      <div class="outline-title">Outline</div>
      <div class="outline-list">
        {outline.map(h => (
          <a
            href={`#${h.slug}`}
            class:list={['outline-item', `outline-h${h.depth}`]}
            data-slug={h.slug}
          >
            {h.text}
          </a>
        ))}
      </div>
    </nav>
  )}

  <div id="post-body">
    <slot />
  </div>
</article>

<div class="prose m-auto mt-8 mb-8 slide-enter animate-delay-500">
  <br>
  <span class="font-mono op50">&gt;&nbsp;</span>
  <a
    href="/posts"
    class="font-mono no-underline op50 hover:op75"
  >cd ..</a>
</div>

<script>
  // Scroll spy: highlight the outline item matching the current scroll position
  const outline = document.getElementById('post-outline')
  if (outline) {
    const items = outline.querySelectorAll<HTMLAnchorElement>('.outline-item')
    const anchors = [...items].map(item => document.getElementById(item.dataset.slug!)).filter(Boolean) as HTMLElement[]

    function updateActive() {
      let current = ''
      for (const anchor of anchors) {
        if (anchor.getBoundingClientRect().top <= 120) {
          current = anchor.id
        }
      }
      items.forEach(item => {
        item.classList.toggle('outline-active', item.dataset.slug === current)
      })
    }

    window.addEventListener('scroll', updateActive, { passive: true })
    updateActive()

    // Smooth scroll on click
    items.forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault()
        const target = document.getElementById(item.dataset.slug!)
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' })
        }
      })
    })
  }

  // Auto-extract first image from article body as cover if no frontmatter image
  const coverEl = document.getElementById('post-cover')
  const bodyEl = document.getElementById('post-body')
  if (coverEl && bodyEl && !coverEl.querySelector('img')) {
    // Find the first <img> in the body (may be wrapped in <p>)
    const firstP = bodyEl.querySelector('p')
    const firstImg = firstP?.querySelector('img') || bodyEl.querySelector('img')
    if (firstImg) {
      // Move the image to the cover container
      const wrapper = firstImg.closest('p') || firstImg
      coverEl.appendChild(firstImg)
      coverEl.style.display = ''
      // Remove empty <p> wrapper if it only contained the image
      if (firstP && !firstP.textContent?.trim() && !firstP.querySelector('img')) {
        firstP.remove()
      }
    }
  }
</script>

<style>
  .post-cover {
    margin-bottom: 2rem;
    border-radius: 12px;
    overflow: hidden;
    line-height: 0;
  }
  .post-cover img {
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
    border-radius: 12px;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
    opacity: 0.5;
    margin-top: -1.5rem;
    margin-bottom: 2rem;
    font-size: 0.9em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.85em;
    color: inherit;
    text-decoration: none;
    padding: 0.1rem 0.5rem;
    border: 1px solid rgba(125, 125, 125, 0.2);
    border-radius: 99px;
    transition: background 0.15s, border-color 0.15s;
  }
  .post-tag:hover {
    background: rgba(125, 125, 125, 0.08);
    border-color: rgba(125, 125, 125, 0.35);
  }

  .post-outline {
    margin-bottom: 2rem;
    padding: 1rem 1.2rem;
    border-radius: 10px;
    border: 1px solid rgba(125, 125, 125, 0.12);
    background: rgba(125, 125, 125, 0.03);
  }

  .outline-title {
    font-size: 0.8em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.45;
    margin-bottom: 0.5rem;
    font-family: 'DM Mono', monospace;
  }

  .outline-list {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .outline-item {
    display: block;
    font-size: 0.88em;
    color: inherit;
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    opacity: 0.55;
    transition: background 0.15s, opacity 0.15s, color 0.15s;
    line-height: 1.5;
  }
  .outline-item:hover {
    background: rgba(125, 125, 125, 0.06);
    opacity: 0.85;
  }
  .outline-item.outline-active {
    opacity: 1;
    background: rgba(125, 125, 125, 0.08);
    font-weight: 500;
  }

  .outline-h1 {
    padding-left: 0.5rem;
  }
  .outline-h2 {
    padding-left: 1.2rem;
  }
</style>
