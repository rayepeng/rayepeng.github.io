---
import Default from '~/layouts/Default.astro'
import { media, type MediaType } from '~/data/media'

const typeLabels: Record<MediaType, string> = {
  anime: 'Anime',
  book: 'Books',
  movie: 'Movies',
  drama: 'Drama',
  game: 'Games',
  song: 'Music',
}

const typeOrder: MediaType[] = ['anime', 'book', 'movie', 'drama', 'game', 'song']
---

<Default title="Media - Anthony Fu" description="Media that Anthony Fu has consumed">
  <div class="prose m-auto slide-enter-content">
    <h1>Media</h1>

    {typeOrder.map((type) => {
      const items = media[type]
      if (!items || !items.length) return null
      return (
        <div class="slide-enter" style={`--enter-stage: ${typeOrder.indexOf(type)}; --enter-step: 50ms;`}>
          <h2>{typeLabels[type]}</h2>
          <div class="columns-1 md:columns-2 xl:columns-3 gap-4">
            {items.map((item) => (
              <div class="mb-2 break-inside-avoid">
                <span class="op-80">{item.name}</span>
                {item.creator && <span class="op-40 text-sm ml-1">— {item.creator}</span>}
              </div>
            ))}
          </div>
        </div>
      )
    })}
  </div>
</Default>