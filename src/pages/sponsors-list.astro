---
import Default from '~/layouts/Default.astro'
import SponsorButtons from '~/components/SponsorButtons.astro'
---

<Default title="Sponsors - Anthony Fu" description="Sponsors of Anthony Fu">
  <div class="prose pb-5 mx-auto" data-slide-enter style="--enter-stage: 2;">
    <SponsorButtons />
    <hr />
  </div>

  <div class="prose m-auto slide-enter-content" style="--enter-stage: 4;">
    <div class="text-center">
      <h2 class="text-2xl font-bold op-80">Great thanks for all the Sponsors!</h2>
      <p class="op-60 mt-2">Your support makes open source sustainable.</p>
    </div>

    <!-- sponsorkit SVG placeholder — will be wired via scripts/sponsorkit in P7 -->
    <div class="text-center op-40 text-sm mt-8">
      Sponsor avatars SVG will be generated by sponsorkit in P7.
    </div>
  </div>
</Default>