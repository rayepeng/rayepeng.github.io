---
import Default from '~/layouts/Default.astro'
import ArtPaths from '~/components/ArtPaths.vue'

const socials = [
  { name: 'Twitter', href: 'https://twitter.com/rayepeng_', icon: 'i-ri-twitter-x-fill' },
  { name: 'GitHub', href: 'https://github.com/rayepeng', icon: 'i-simple-icons-github' },
  { name: 'Telegram', href: 'https://t.me/RayeJourney', icon: 'i-ri-telegram-fill' },
  { name: 'Medium', href: 'https://medium.com/@rayepeng', icon: 'i-simple-icons-medium' },
  { name: 'Steam', href: 'https://steamcommunity.com/profiles/76561198800631930/', icon: 'i-simple-icons-steam' },
]
---

<Default
  title="Raye's Journey"
  description="无人调护，自去经心"
>
  <ArtPaths client:load />
  <div class="prose m-auto slide-enter-content">
    <h1>Hi, I'm Raye <span class="vp-wisper">_journey_</span></h1>

    <p>嘿！我是 Raye，一个热爱技术与记录的打工人。</p>

    <p>
      一个想成为黑客的文人，ENFJ-A，随时欢迎打扰。
      喜欢追剧、记录、阅读、运动，御三家+Steam Deck 重度游戏玩家。
    </p>

    <p>
      在这里记录技术思考、生活片段和一些胡思乱想。
      尽量做到每周更新两篇，一篇技术/杂文，一篇周报。
    </p>

    <p>
      平时也会打打羽毛球（左撇子选手），偶尔也会跑跑步。
      照片发在 <a href="https://photo.rayepeng.net/" target="_blank" rel="noopener noreferrer">photo.rayepeng.net</a>，
      跑步记录在 <a href="https://rayepeng.net/workouts_page/" target="_blank" rel="noopener noreferrer">workouts_page</a>。
    </p>

    <div class="flex-auto" />

    <hr />

    <p>找到我</p>

    <p class="flex gap-3 flex-wrap mt--2!">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="magic-link">
          <span class={`${s.icon} op75`} /> {s.name}
        </a>
      ))}
    </p>
  </div>
</Default>

<style>
  .magic-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    text-decoration-color: var(--c-border, currentColor);
  }
  .magic-link span:first-child {
    display: inline-block;
    width: 1em;
    height: 1em;
  }
  .vp-wisper {
    font-family: 'Bad Script', serif;
    opacity: 0.6;
    font-size: 0.85em;
    margin-left: 0.5em;
  }
</style>
