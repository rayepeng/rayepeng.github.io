---
import { getCollection } from 'astro:content'
import Default from '~/layouts/Default.astro'

const all = await getCollection('posts', ({ data }) => !data.draft && !data.redirect)

// Collect tags with counts and posts
const tagMap = new Map<string, { count: number; posts: { title: string; slug: string; date: string }[] }>()

for (const post of all) {
  const tags: string[] = (post.data as any).tags ?? []
  const postSlug = (post.data as any).customSlug || post.slug
  if (!tags || !tags.length) {
    const t = '未标签'
    if (!tagMap.has(t)) tagMap.set(t, { count: 0, posts: [] })
    tagMap.get(t)!.count++
    tagMap.get(t)!.posts.push({
      title: post.data.title,
      slug: postSlug,
      date: typeof post.data.date === 'string' ? post.data.date : post.data.date?.toISOString?.() ?? '',
    })
    continue
  }
  for (const tag of tags) {
    if (!tagMap.has(tag)) tagMap.set(tag, { count: 0, posts: [] })
    tagMap.get(tag)!.count++
    tagMap.get(tag)!.posts.push({
      title: post.data.title,
      slug: postSlug,
      date: typeof post.data.date === 'string' ? post.data.date : post.data.date?.toISOString?.() ?? '',
    })
  }
}

// Sort tags by count desc
const sortedTags = [...tagMap.entries()]
  .sort((a, b) => b[1].count - a[1].count)

const maxCount = Math.max(...sortedTags.map(([, v]) => v.count), 1)
const minCount = Math.min(...sortedTags.map(([, v]) => v.count), 1)

function tagSize(count: number) {
  const ratio = maxCount === minCount ? 0.5 : (count - minCount) / (maxCount - minCount)
  return 0.8 + ratio * 1.6
}

function tagOpacity(count: number) {
  const ratio = maxCount === minCount ? 0.5 : (count - minCount) / (maxCount - minCount)
  return 0.45 + ratio * 0.55
}

// Encode for client
const tagsData = sortedTags.map(([tag, { count }]) => ({
  tag,
  count,
  size: tagSize(count),
  opacity: tagOpacity(count),
}))
---

<Default title="Tags — Raye's Journey" description="All blog post tags">
  <div class="prose m-auto slide-enter-content">
    <h1>Tags</h1>

    <!-- Tag Cloud -->
    <h2 id="tag-cloud">Tag Cloud</h2>
    <div class="not-prose tag-cloud">
      {tagsData.map(({ tag, count, size, opacity }) => (
        <a
          href={`#tag-${encodeURIComponent(tag)}`}
          class="tag-cloud-item"
          style={`font-size:${size}rem; opacity:${opacity}`}
          title={`${tag} (${count})`}
        >
          {tag}
        </a>
      ))}
    </div>

    <hr />

    <!-- Tag List with collapsible sections -->
    <h2 id="tag-list">All Tags</h2>
    <div class="not-prose" id="tag-list-area">
      {sortedTags.map(([tag, { count, posts }]) => (
        <div class="tag-section" id={`tag-${encodeURIComponent(tag)}`}>
          <div class="tag-header" data-tag={tag}>
            <span class="tag-toggle i-carbon-chevron-right"></span>
            <span class="tag-hash">#</span>
            <span class="tag-name">{tag}</span>
            <span class="tag-badge">{count}</span>
          </div>
          <div class="tag-body">
            <div class="tag-body-inner">
              {posts
                .sort((a, b) => +new Date(b.date) - +new Date(a.date))
                .map((post) => (
                  <a href={`/posts/${post.slug}`} class="tag-post-item">
                    <span class="tag-post-icon i-carbon-document"></span>
                    <span class="tag-post-title">{post.title}</span>
                    <span class="tag-post-date">
                      {post.date ? new Date(post.date).toISOString().slice(0, 10) : ''}
                    </span>
                  </a>
                ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Default>

<script>
  function toggleTagSection(header: HTMLElement, expand: boolean) {
    const section = header.parentElement as HTMLElement
    if (!section) return
    section.classList.toggle('is-open', expand)
  }

  // Enable expand/collapse for each tag section
  document.querySelectorAll('.tag-header').forEach((header) => {
    header.addEventListener('click', () => {
      const section = header.parentElement as HTMLElement
      if (!section) return
      toggleTagSection(header as HTMLElement, !section.classList.contains('is-open'))
    })
  })

  // Auto-expand the tag section matching the URL hash
  function expandFromHash() {
    const hash = location.hash.slice(1) // e.g. "tag-生活"
    if (!hash.startsWith('tag-')) return
    const section = document.getElementById(hash)
    if (!section) {
      // Try decoded version
      const decoded = decodeURIComponent(hash)
      const decodedSection = document.getElementById(decoded)
      if (decodedSection) {
        const header = decodedSection.querySelector('.tag-header') as HTMLElement
        if (header) toggleTagSection(header, true)
      }
      return
    }
    const header = section.querySelector('.tag-header') as HTMLElement
    if (header) toggleTagSection(header, true)
  }

  expandFromHash()
  window.addEventListener('hashchange', expandFromHash)
</script>

<style is:global>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem 0.8rem;
    padding: 1.5rem 1rem;
    border-radius: 12px;
    background: rgba(125, 125, 125, 0.03);
    border: 1px solid rgba(125, 125, 125, 0.1);
  }

  .tag-cloud-item {
    display: inline-block;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    line-height: 1.3;
    transition: transform 0.2s, opacity 0.2s;
    cursor: pointer;
  }
  .tag-cloud-item:hover {
    transform: scale(1.12);
    opacity: 1 !important;
  }

  .tag-section {
    margin-bottom: 0.6rem;
    user-select: none;
  }

  .tag-header {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .tag-header:hover {
    background: rgba(125, 125, 125, 0.08);
  }

  .tag-toggle {
    font-size: 0.75em;
    opacity: 0.45;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    transform: rotate(0deg);
  }
  .tag-section.is-open .tag-toggle {
    transform: rotate(90deg);
  }

  .tag-hash {
    font-weight: 700;
    opacity: 0.3;
    font-size: 0.85em;
  }

  .tag-name {
    font-weight: 600;
    font-size: 0.95em;
  }

  .tag-badge {
    font-size: 0.65em;
    background: rgba(125, 125, 125, 0.12);
    color: rgba(125, 125, 125, 0.8);
    padding: 0.1rem 0.4rem;
    border-radius: 99px;
    font-family: 'DM Mono', monospace;
  }

  /* Smooth collapse using grid-template-rows trick */
  .tag-body {
    display: grid;
    grid-template-rows: 0fr;
    padding-left: 1rem;
    border-left: 2px solid rgba(125, 125, 125, 0);
    margin-left: 0.55rem;
    transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                border-left-color 0.35s ease;
  }
  .tag-section.is-open .tag-body {
    grid-template-rows: 1fr;
    border-left-color: rgba(125, 125, 125, 0.1);
  }
  .tag-body-inner {
    overflow: hidden;
    min-height: 0;
  }

  .tag-post-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.5rem;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    transition: background 0.15s;
  }
  .tag-post-item:hover {
    background: rgba(125, 125, 125, 0.06);
  }

  .tag-post-icon {
    font-size: 0.8em;
    opacity: 0.35;
  }

  .tag-post-title {
    flex: 1;
    font-size: 0.88em;
  }

  .tag-post-date {
    font-size: 0.72em;
    opacity: 0.35;
    font-family: 'DM Mono', monospace;
    flex-shrink: 0;
  }
</style>
