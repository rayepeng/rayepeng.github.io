---
import Default from '~/layouts/Default.astro'
import ListProjects from '~/components/ListProjects.astro'

const projects = {
  'Projects': [
    { name: 'rayepeng.github.io', link: 'https://github.com/rayepeng/rayepeng.github.io', desc: 'Personal blog built with Astro + Fuwari', icon: 'i-simple-icons-github' },
    { name: 'photo.rayepeng.net', link: 'https://photo.rayepeng.net/', desc: 'Photography gallery site', icon: 'i-ri-camera-line' },
    { name: 'page.raye.wiki', link: 'https://page.raye.wiki/', desc: 'Quick notes and snippets', icon: 'i-ri-sticky-note-line' },
    { name: 'raye.wiki', link: 'https://raye.wiki/', desc: 'Knowledge base and wiki', icon: 'i-ri-book-open-line' },
  ],
}
---

<Default title="Projects — Raye's Journey" description="List of projects" hideProse>
  <div class="max-w-300 m-auto mt-4 slide-enter-content text-center">
    <h1 class="text-4xl font-bold op-80">Projects</h1>
    <p class="op-50 text-lg mt-2">一些个人项目和站点</p>
  </div>
  <ListProjects projects={projects} />
</Default>
