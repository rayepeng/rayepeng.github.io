---

<Default title="Projects - Anthony Fu" description="List of projects that I am proud of" hideProse>
  <div class="max-w-300 m-auto mt-4 slide-enter-content text-center">
    <h1 class="text-4xl font-bold op-80">Projects</h1>
    <p class="op-50 text-lg mt-2">List of projects that I am proud of</p>
  </div>
  <ListProjects projects={projects} />
</Default>