---
import { getCollection } from 'astro:content'
import Default from '~/layouts/Default.astro'

const all = await getCollection('posts', ({ data }) => !data.draft && !data.redirect)

// Build category → posts map from frontmatter `category`
interface TreeNode {
  name: string
  slug: string
  posts: { title: string; slug: string; date: string }[]
  children: TreeNode[]
}

const categories = new Map<string, { title: string; slug: string; date: string }[]>()

for (const post of all) {
  const cat = (post.data as any).category || '未分类'
  if (!categories.has(cat)) categories.set(cat, [])
  categories.get(cat)!.push({
    title: post.data.title,
    slug: (post.data as any).customSlug || post.slug,
    date: typeof post.data.date === 'string' ? post.data.date : post.data.date?.toISOString?.() ?? '',
  })
}

// Sort: category name alphabetically, posts by date desc
const sortedCats = [...categories.entries()]
  .sort((a, b) => a[0].localeCompare(b[0], 'zh-CN'))
  .map(([name, posts]) => ({
    name,
    posts: posts.sort((a, b) => +new Date(b.date) - +new Date(a.date)),
  }))

const totalPosts = sortedCats.reduce((s, c) => s + c.posts.length, 0)

// Encode for client
const catsData = sortedCats.map(c => ({
  name: c.name,
  count: c.posts.length,
  posts: c.posts.map(p => ({
    title: p.title,
    slug: p.slug,
    date: p.date ? new Date(p.date).toISOString().slice(0, 10) : '',
  })),
}))
---

<Default title="Categories — Raye's Journey" description="Browse posts by category">
  <div class="prose m-auto slide-enter-content">
    <h1>Categories</h1>
    <p class="op50 mt-0!">共 {totalPosts} 篇文章，{sortedCats.length} 个分类</p>

    <div class="not-prose" id="cat-root" data-json={JSON.stringify(catsData)} />
  </div>
</Default>

<script>
  interface TagCat {
    name: string
    count: number
    posts: { title: string; slug: string; date: string }[]
  }

  function render(el: HTMLElement, cats: TagCat[]) {
    for (const cat of cats) {
      const section = document.createElement('div')
      section.className = 'tree-folder'

      // Header
      const header = document.createElement('div')
      header.className = 'tree-header'
      header.innerHTML = `
        <span class="tree-toggle i-carbon-chevron-up"></span>
        <span class="tree-folder-icon i-carbon-folder"></span>
        <span class="tree-folder-name">${cat.name}</span>
        <span class="tree-count">${cat.count}</span>
      `
      section.appendChild(header)

      // Body (collapsed by default)
      const body = document.createElement('div')
      body.className = 'tree-body'
      const bodyInner = document.createElement('div')
      bodyInner.className = 'tree-body-inner'
      body.appendChild(bodyInner)

      for (const post of cat.posts) {
        const a = document.createElement('a')
        a.href = `/posts/${post.slug}`
        a.className = 'tree-file'
        a.innerHTML = `
          <span class="tree-file-icon i-carbon-document"></span>
          <span class="tree-file-name">${post.title}</span>
          <span class="tree-date">${post.date}</span>
        `
        bodyInner.appendChild(a)
      }

      section.appendChild(body)

      // Toggle interaction — arrow rotates, folder icon swaps, body slides
      header.addEventListener('click', () => {
        const isOpen = section.classList.toggle('is-open')
        const icon = header.querySelector('.tree-folder-icon')!
        icon.className = `tree-folder-icon i-carbon-folder${isOpen ? '-open' : ''}`
      })

      el.appendChild(section)
    }
  }

  const root = document.getElementById('cat-root')
  if (root) {
    const data: TagCat[] = JSON.parse(root.dataset.json!)
    render(root, data)
  }
</script>

<style is:global>
  .tree-folder {
    user-select: none;
  }

  .tree-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .tree-header:hover {
    background: rgba(125, 125, 125, 0.08);
  }

  .tree-toggle {
    font-size: 0.8em;
    opacity: 0.5;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    transform: rotate(0deg);
  }
  .tree-folder.is-open .tree-toggle {
    transform: rotate(180deg);
  }

  .tree-folder-icon {
    font-size: 1.05em;
    opacity: 0.45;
    transition: opacity 0.2s;
  }

  .tree-folder-name {
    font-weight: 500;
    font-size: 0.95em;
  }

  .tree-count {
    font-size: 0.7em;
    opacity: 0.4;
    margin-left: 0.3rem;
    font-family: 'DM Mono', monospace;
  }

  /* Smooth collapse using grid-template-rows trick — no JS height measurement */
  .tree-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    padding-left: 1.2rem;
    border-left: 1px solid rgba(125, 125, 125, 0);
    margin-left: 0.45rem;
    transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                border-left-color 0.35s ease;
  }
  .tree-folder.is-open .tree-body {
    grid-template-rows: 1fr;
    border-left-color: rgba(125, 125, 125, 0.12);
  }
  .tree-body-inner {
    overflow: hidden;
    min-height: 0;
  }

  .tree-file {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.5rem;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    transition: background 0.15s;
  }
  .tree-file:hover {
    background: rgba(125, 125, 125, 0.06);
  }

  .tree-file-icon {
    font-size: 0.85em;
    opacity: 0.4;
  }

  .tree-file-name {
    flex: 1;
    font-size: 0.88em;
  }

  .tree-date {
    font-size: 0.72em;
    opacity: 0.35;
    font-family: 'DM Mono', monospace;
    flex-shrink: 0;
  }
</style>
