---
import { getCollection } from 'astro:content'
import Default from '~/layouts/Default.astro'
import SubNav from '~/components/SubNav.astro'
import ListPosts from '~/components/ListPosts.astro'

/**
 * Feed Content Collection posts into ListPosts for consistent
 * year-grouped layout with background year labels.
 */
const all = await getCollection('posts', ({ data }) => !data.draft)

const postItems = all
  .map((post) => ({
    slug: (post.data as any).customSlug || post.slug,
    title: post.data.title,
    date: post.data.date,
    lang: post.data.lang,
    redirect: post.data.redirect,
    duration: post.data.duration,
  }))
  .sort((a, b) => +new Date(b.date) - +new Date(a.date))
---

<Default title="Blog — Raye's Journey" description="Raye's Journey">
  <SubNav active="/posts" />

  <div class="prose m-auto slide-enter-content">
    <ListPosts posts={postItems} />
  </div>
</Default>
