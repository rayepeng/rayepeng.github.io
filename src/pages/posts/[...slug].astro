---
import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'
import Default from '~/layouts/Default.astro'
import PostLayout from '~/layouts/PostLayout.astro'
import SubNav from '~/components/SubNav.astro'

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts', ({ data }) => !data.draft)
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}) satisfies GetStaticPaths

const { entry } = Astro.props
const { title, date, description, image, lang, redirect } = entry.data
// Extract tags and category from data (may be undefined for legacy posts)
const tags: string[] = (entry.data as any).tags ?? []
const category: string = (entry.data as any).category ?? ''

const { Content, headings, remarkPluginFrontmatter } = await entry.render()
---

{redirect ? (
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <title>{title} — Redirecting...</title>
      <link rel="canonical" href={redirect} />
      <meta http-equiv="refresh" content={`0;url=${redirect}`} />
    </head>
    <body>
      <p>Redirecting to <a href={redirect}>{redirect}</a>...</p>
    </body>
  </html>
) : (

<Default title={`${title} — Raye's Journey`} description={description || title}>
  <SubNav active="/posts" />
  <PostLayout title={title} date={date} description={description} image={image} lang={lang} tags={tags} category={category} headings={headings}>
    <Content />
  </PostLayout>
</Default>

)}
